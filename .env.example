# Clerk — from https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk redirect URLs (set these in Clerk dashboard too under Redirect URLs)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth/device
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth/device

# Neon / Vercel Postgres — from your database dashboard
STORAGE_DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
